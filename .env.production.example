# Production Environment Configuration
# Copy this file to .env.production and fill in your values

# ========================================
# Redis Cloud Configuration
# ========================================

# Option 1: Redis Cloud URI (Recommended)
# Get this from your Redis Cloud dashboard
# Format: redis://default:password@host:port
# Or with SSL: rediss://default:password@host:port
REDIS_URI=redis://default:YOUR_PASSWORD@YOUR_REDIS_HOST:YOUR_REDIS_PORT

# Option 2: Individual Redis settings (if not using URI)
# REDIS_HOST=your-redis-host.cloud.redislabs.com
# REDIS_PORT=12345
# REDIS_DB=0

# ========================================
# Redis Index Configuration
# ========================================

# These should match your existing Redis setup
REDIS_INDEX_NAME=celeb_faces_idx
REDIS_KEY_PREFIX=celeb

# ========================================
# Application Configuration
# ========================================

# Backend API URL (for frontend to connect)
# In production, this should be your backend's public URL
VITE_API_URL=http://your-backend-domain.com

# WebSocket URL (for frontend to connect)
# In production, this should be your backend's WebSocket URL
VITE_WS_URL=ws://your-backend-domain.com/ws
# Or with SSL: wss://your-backend-domain.com/ws

